---
interface Props {
  eyebrow?: string;
  title: string;
  subhead?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const {
  eyebrow,
  title,
  subhead,
  align = 'left',
  light = false,
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = light ? 'text-cream' : 'text-ink';
const subColor = light ? 'text-cream/80' : 'text-ink-muted';
---

<div class={`max-w-3xl ${alignClass}`}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class={`section-heading ${titleColor} mb-4`}>{title}</h2>
  {subhead && (
    <p class={`text-lg md:text-xl leading-relaxed ${subColor}`}>{subhead}</p>
  )}
</div>
