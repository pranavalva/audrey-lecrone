---
import type { Service } from '@/data/types';

interface Props {
  service: Service;
}

const { service } = Astro.props;
const href = `/${service.audience}/${service.slug}`;
const whoItsFor = service.whoItsFor.split('.')[0] + '.';
---

<article class="group flex flex-col h-full bg-cream rounded-2xl border border-cream-deep overflow-hidden shadow-card hover:shadow-lg transition-shadow duration-300">
  <div class="p-6 md:p-8 flex flex-col flex-1">
    <span class="inline-block self-start px-3 py-1 mb-4 text-xs font-semibold uppercase tracking-wider text-ink bg-gold/20 rounded-full">
      {service.format}
    </span>
    <h3 class="font-serif text-2xl font-semibold text-ink mb-3 group-hover:text-coral transition-colors">
      {service.title}
    </h3>
    <div class="mb-4 pb-4 border-b border-cream-deep">
      <p class="text-xs font-semibold uppercase tracking-widest text-gold mb-1.5">Who it's for</p>
      <p class="text-sm text-ink-muted font-serif italic leading-snug">{whoItsFor}</p>
    </div>
    <p class="text-ink-muted leading-relaxed flex-1 mb-6">{service.cardDescription}</p>
    {service.outcome && (
      <p class="text-sm text-ink-muted/80 italic mb-4">{service.outcome}</p>
    )}
    <a
      href={href}
      class="inline-flex items-center min-h-[44px] text-coral font-medium hover:text-coral-hover transition-colors"
    >
      {service.ctaText} →
    </a>
  </div>
</article>
