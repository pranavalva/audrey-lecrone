---
interface Props {
  src?: string;
  alt?: string;
  aspect?: 'square' | 'video' | 'portrait' | 'wide';
  class?: string;
  label?: string;
}

const {
  src = '',
  alt = 'Placeholder image',
  aspect = 'video',
  class: className = '',
  label = 'Replace with photo',
} = Astro.props;

const aspectClasses = {
  square: 'aspect-square',
  video: 'aspect-video',
  portrait: 'aspect-[3/4]',
  wide: 'aspect-[21/9]',
};
---

<div
  class={`relative overflow-hidden bg-cream-deep ${aspectClasses[aspect]} ${className}`}
  role="img"
  aria-label={alt}
>
  <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center">
    <svg
      class="w-10 h-10 text-ink/20 mb-2"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
      ></path>
    </svg>
    <span class="text-xs font-medium uppercase tracking-wider text-ink/40">{label}</span>
    {src && (
      <span class="text-[10px] text-ink/30 mt-1 font-mono truncate max-w-full">{src}</span>
    )}
  </div>
</div>
