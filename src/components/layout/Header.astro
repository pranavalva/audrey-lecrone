---
import { nav, site } from '@/data/site';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-cream-deep">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center text-ink hover:text-coral transition-colors" aria-label="Home">
        <img
          src="/images/audrey lecrone logo aac.png"
          alt="Audrey LeCrone"
          class="h-24 md:h-28 object-contain"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors min-h-[44px] inline-flex items-center',
              isActive(item.href)
                ? 'text-coral'
                : 'text-ink hover:text-coral',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        class="md:hidden min-h-[44px] min-w-[44px] flex items-center justify-center text-ink"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-cream-deep bg-cream"
    aria-label="Mobile navigation"
  >
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'min-h-[44px] flex items-center text-base font-medium border-b border-cream-deep last:border-0 transition-colors',
            isActive(item.href) ? 'text-coral' : 'text-ink hover:text-coral',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isOpen));
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      });
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
