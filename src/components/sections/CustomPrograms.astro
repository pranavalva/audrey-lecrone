---
import Button from '@/components/ui/Button.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
---

<section class="section-dark py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <ScrollReveal>
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">Custom programs</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-cream mb-4 text-balance">
          Something built just for your team
        </h2>
        <p class="text-cream/70 text-lg leading-relaxed mb-4">
          Not every organization fits a standard workshop. Audrey co-designs programs with your leadership team—tailored to your culture, challenges, and goals.
        </p>
        <p class="text-cream/70 leading-relaxed mb-8">
          Flexible format: half-day intensives, multi-week series, keynote + follow-up coaching, or fully bespoke engagements. Let's figure out what your team actually needs.
        </p>
        <Button href="/contact?from=organizations&service=custom" variant="primary">
          Let's design something together
        </Button>
      </div>
    </ScrollReveal>
  </div>
</section>
