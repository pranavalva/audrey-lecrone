---
import PlaceholderImage from '@/components/ui/PlaceholderImage.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';

interface Props {
  title: string;
  intro: string;
  image: string;
}

const { title, intro, image } = Astro.props;
---

<section class="relative">
  <PlaceholderImage
    src={image}
    alt={title}
    aspect="wide"
    class="w-full max-h-[50vh] object-cover"
  />
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <ScrollReveal>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-ink mb-4 text-balance">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-3xl">
        {intro}
      </p>
    </ScrollReveal>
  </div>
</section>
