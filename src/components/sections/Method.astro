---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import { methodPillars } from '@/data/homepage';
---

<section class="section-dark py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <ScrollReveal>
      <SectionHeading
        eyebrow="How I work"
        title="Technical precision. Emotional truth."
        subhead="Four pillars that shape how I work with every client."
        light
        align="center"
      />
    </ScrollReveal>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {methodPillars.map((pillar, i) => (
        <ScrollReveal>
          <div class="p-6 md:p-8 rounded-2xl border border-cream/10 bg-cream/5">
            <span class="text-gold font-serif text-3xl font-semibold">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-serif text-xl font-semibold text-cream mt-3 mb-2">{pillar.title}</h3>
            <p class="text-cream/70 leading-relaxed">{pillar.description}</p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
