---
import Button from '@/components/ui/Button.astro';
import PlaceholderImage from '@/components/ui/PlaceholderImage.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import type { Audience, Service } from '@/data/types';

interface Props {
  service: Service;
}

const { service } = Astro.props;
const contactHref = `/contact?from=${service.audience}&service=${service.slug}`;
const backHref = `/${service.audience}`;

const backLabels: Record<Audience, string> = {
  actors: 'All actor services',
  professionals: 'All professional services',
  organizations: 'All organization programs',
};
---

<article>
  <PlaceholderImage
    src={service.headerImage}
    alt={service.title}
    aspect="wide"
    class="w-full max-h-[40vh]"
  />

  <div class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-16">
      <div class="lg:col-span-2">
        <ScrollReveal>
          <a
            href={backHref}
            class="inline-flex items-center min-h-[44px] mb-6 text-sm font-medium text-coral hover:text-coral-hover transition-colors"
          >
            ← {backLabels[service.audience]}
          </a>

          <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold uppercase tracking-wider text-ink bg-gold/20 rounded-full">
            {service.format}
          </span>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold text-ink mb-4 text-balance">
            {service.title}
          </h1>
          <p class="text-xl text-ink-muted leading-relaxed mb-8">
            {service.summary}
          </p>

          <div class="space-y-4 mb-10">
            {service.paragraphs.map((p) => (
              <p class="text-ink-muted leading-relaxed text-lg">{p}</p>
            ))}
          </div>

          {service.testimonial && (
            <blockquote class="mb-10 p-6 md:p-8 bg-cream-deep/50 rounded-2xl border border-cream-deep border-l-4 border-l-coral">
              <p class="text-ink-muted leading-relaxed text-lg font-serif italic mb-4">
                "{service.testimonial.quote}"
              </p>
              <footer>
                <p class="font-semibold text-ink">{service.testimonial.name}</p>
                <p class="text-sm text-ink-muted">{service.testimonial.role}</p>
              </footer>
            </blockquote>
          )}

          {service.onlineCourse && (
            <div class="mb-10 p-6 md:p-8 rounded-2xl border border-gold/30 bg-gold/5">
              <p class="eyebrow mb-2">Or learn at your own pace</p>
              <h2 class="font-serif text-xl font-semibold text-ink mb-2">
                {service.onlineCourse.title}
              </h2>
              <p class="text-ink-muted leading-relaxed mb-5">
                {service.onlineCourse.description}
              </p>
              <Button
                href={service.onlineCourse.url}
                variant="secondary"
                target="_blank"
                rel="noopener noreferrer"
              >
                {service.onlineCourse.ctaLabel}
              </Button>
            </div>
          )}

          <h2 class="font-serif text-2xl font-semibold text-ink mb-4">What's included</h2>
          <ul class="space-y-3 mb-10">
            {service.highlights.map((item) => (
              <li class="flex gap-3 text-ink-muted">
                <span class="text-coral shrink-0 mt-1">✦</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-col sm:flex-row gap-4">
            <Button href={contactHref} fullWidth class="sm:w-auto sm:inline-flex">
              Start a conversation
            </Button>
            <Button href={backHref} variant="secondary" fullWidth class="sm:w-auto sm:inline-flex">
              ← {backLabels[service.audience]}
            </Button>
          </div>
        </ScrollReveal>
      </div>

      <aside class="lg:col-span-1">
        <ScrollReveal>
          <div class="sticky top-24 p-6 md:p-8 bg-cream-deep/50 rounded-2xl border border-cream-deep">
            <h2 class="font-serif text-xl font-semibold text-ink mb-4">Who it's for</h2>
            <p class="text-ink-muted leading-relaxed mb-6">{service.whoItsFor}</p>

            <div class="p-4 bg-cream rounded-xl border border-cream-deep mb-6">
              <p class="text-sm text-ink-muted leading-relaxed">
                There's no online booking or published rates. Every engagement starts with a conversation to find the right fit.
              </p>
            </div>

            <Button href={contactHref} fullWidth>
              Get in touch
            </Button>

            {service.onlineCourse && (
              <a
                href={service.onlineCourse.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block mt-4 text-center min-h-[44px] leading-[44px] text-sm font-medium text-ink hover:text-coral transition-colors"
              >
                {service.onlineCourse.ctaLabel} →
              </a>
            )}

            <a
              href={backHref}
              class="block mt-4 text-center min-h-[44px] leading-[44px] text-sm text-coral hover:text-coral-hover transition-colors"
            >
              ← {backLabels[service.audience]}
            </a>
          </div>
        </ScrollReveal>
      </aside>
    </div>
  </div>
</article>
