---
import Button from '@/components/ui/Button.astro';
import PlaceholderImage from '@/components/ui/PlaceholderImage.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import { hero } from '@/data/homepage';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-cream via-cream to-coral/5 pointer-events-none" />
  <div class="relative max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <ScrollReveal>
        <p class="eyebrow mb-4">Dialect & Communication Coaching</p>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-semibold text-ink leading-tight mb-6">
          Accents & Authenticity,<br />Personality & Presence
        </h1>
        <p class="text-lg md:text-xl text-ink-muted leading-relaxed mb-8">
          {hero.subhead}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={hero.primaryCta.href} fullWidth>
            {hero.primaryCta.label}
          </Button>
          <Button href={hero.secondaryCta.href} variant="secondary" fullWidth>
            {hero.secondaryCta.label}
          </Button>
        </div>
      </ScrollReveal>

      <ScrollReveal class="flex justify-center lg:justify-end">
        <div class="w-full lg:max-w-2xl overflow-hidden">
          <img
            src={hero.portrait}
            alt="Audrey LeCrone — dialect coach"
            class="w-full h-auto object-cover object-top"
          />
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
