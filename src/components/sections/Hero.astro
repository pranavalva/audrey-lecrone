---
import Button from '@/components/ui/Button.astro';
import PlaceholderImage from '@/components/ui/PlaceholderImage.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import { hero } from '@/data/homepage';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-cream via-cream to-coral/5 pointer-events-none" />
  <div class="relative max-w-6xl mx-auto px-4 md:px-6 py-16 md:py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <ScrollReveal>
        <p class="eyebrow mb-4">Dialect & Communication Coaching</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-ink leading-tight text-balance mb-6">
          {hero.headline}
        </h1>
        <p class="text-lg md:text-xl font-medium text-ink-muted leading-relaxed mb-4 max-w-xl">
          {hero.subheadline}
        </p>
        <p class="text-lg md:text-xl text-ink-muted leading-relaxed mb-8 max-w-xl">
          {hero.subhead}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={hero.primaryCta.href} fullWidth>
            {hero.primaryCta.label}
          </Button>
          <Button href={hero.secondaryCta.href} variant="secondary" fullWidth>
            {hero.secondaryCta.label}
          </Button>
        </div>
      </ScrollReveal>

      <ScrollReveal class="flex justify-center lg:justify-end">
        <div class="w-full max-w-md lg:max-w-lg overflow-hidden rounded-[2rem] shadow-2xl">
          <img
            src={hero.portrait}
            alt="Audrey LeCrone — dialect coach"
            class="w-full aspect-[3/4] object-cover"
          />
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
