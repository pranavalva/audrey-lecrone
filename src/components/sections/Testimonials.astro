---
import Button from '@/components/ui/Button.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import TestimonialCard from '@/components/ui/TestimonialCard.astro';
import { featuredTestimonials } from '@/data/testimonials';
---

<section class="py-16 md:py-24 bg-cream-deep/50">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <ScrollReveal>
      <SectionHeading
        eyebrow="Success Stories"
        title="What clients say"
        subhead="In their own words—from actors, executives, and teams I've coached."
        align="center"
      />
    </ScrollReveal>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {featuredTestimonials.map((testimonial) => (
        <ScrollReveal>
          <TestimonialCard testimonial={testimonial} />
        </ScrollReveal>
      ))}
    </div>

    <ScrollReveal class="mt-10 text-center">
      <Button href="/success-stories" variant="secondary">
        Read more success stories
      </Button>
    </ScrollReveal>
  </div>
</section>
