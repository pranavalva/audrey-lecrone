---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PlaceholderImage from '@/components/ui/PlaceholderImage.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import UnmutedShow from '@/components/sections/UnmutedShow.astro';
import { about } from '@/data/about';

const bodyText = 'text-base text-ink-muted leading-relaxed';
---

<BaseLayout
  title="About Audrey LeCrone"
  description="Hollywood dialect coach, communication expert, and performer. Award-winning coaching for actors, executives, and global professionals."
  canonicalPath="/about"
>
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <ScrollReveal>
          <PlaceholderImage
            src={about.portrait}
            alt="Audrey LeCrone"
            aspect="portrait"
            class="hero-mask w-full max-w-md mx-auto lg:mx-0"
          />
        </ScrollReveal>

        <ScrollReveal>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold text-ink mb-4">
            {about.headline}
          </h1>
          <p class={`${bodyText} mb-6`}>{about.intro}</p>
          <div class="space-y-4">
            {about.bio.map((p) => (
              <p class={bodyText}>{p}</p>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-cream-deep/30">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <ScrollReveal>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-ink mb-6">
          {about.background.title}
        </h2>
        <div class="max-w-3xl space-y-4">
          {about.background.content.map((p) => (
            <p class={bodyText}>{p}</p>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <section class="section-dark py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <ScrollReveal>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-cream mb-6">
          {about.philosophy.title}
        </h2>
        <div class="max-w-3xl space-y-4">
          {about.philosophy.content.map((p) => (
            <p class="text-base text-cream/70 leading-relaxed">{p}</p>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <ScrollReveal>
        <p class="eyebrow mb-4">At a glance</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-ink mb-8">
          Credentials
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl">
          {about.credentials.map((item) => (
            <li class={`flex gap-3 ${bodyText}`}>
              <span class="text-gold shrink-0">✦</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-cream-deep/30">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <ScrollReveal>
        <p class="eyebrow mb-4">In the media</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-ink mb-4">
          {about.featuredOn.title}
        </h2>
        <p class={`${bodyText} max-w-3xl mb-10`}>{about.featuredOn.intro}</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {about.featuredOn.items.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group block p-6 bg-cream rounded-2xl border border-cream-deep shadow-card hover:shadow-lg hover:border-coral/30 transition-all"
            >
              <span class="inline-block px-2.5 py-0.5 mb-3 text-xs font-semibold uppercase tracking-wider text-ink bg-gold/20 rounded-full">
                {item.type}
              </span>
              <h3 class="font-serif text-xl font-semibold text-ink mb-2 group-hover:text-coral transition-colors">
                {item.title}
              </h3>
              <p class={bodyText}>{item.description}</p>
              <span class="inline-flex items-center min-h-[44px] mt-3 text-coral font-medium text-sm">
                Watch or listen →
              </span>
            </a>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <UnmutedShow />
</BaseLayout>
