---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CreditCard from '@/components/ui/CreditCard.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.astro';
import { credits } from '@/data/credits';
---

<BaseLayout
  title="Portfolio"
  description="Film, television, theatre, and corporate projects Audrey LeCrone has coached on. Portfolio of dialect and communication coaching work."
  canonicalPath="/credits"
>
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 md:px-6">
      <ScrollReveal>
        <p class="eyebrow mb-4">Portfolio</p>
        <h1 class="font-serif text-4xl md:text-5xl font-semibold text-ink mb-4 text-balance">
          Work coached on
        </h1>
        <p class="text-lg text-ink-muted leading-relaxed max-w-3xl mb-4">
          This is the work—film, television, theatre, and corporate projects where Audrey has provided dialect and communication coaching. These are credits, not client testimonials.
        </p>
        <p class="text-sm text-ink-muted mb-10">
          Looking for what clients say?{' '}
          <a href="/success-stories" class="text-coral hover:underline">
            Read Success Stories →
          </a>
        </p>
      </ScrollReveal>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {credits.map((credit) => (
          <ScrollReveal>
            <CreditCard credit={credit} />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
